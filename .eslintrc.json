{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "commonjs"
  },
    "rules": {
    "no-unused-vars": ["error", { "vars": "all", "args": "all" }],
    "no-unused-expressions": "error"
    }
}
