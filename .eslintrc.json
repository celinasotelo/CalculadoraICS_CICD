{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "script"
  },
    "rules": {
    "no-unused-vars": ["error", { "vars": "all", "args": "all", "argsIgnorePattern": "^_" }],
    "no-unused-expressions": "error"
  },
  "overrides": [
      {
        "files": ["e2e/**/*.js", "playwright.config.js"],
        "parserOptions": {
          "sourceType": "module"
        }
      }
    ]
}
