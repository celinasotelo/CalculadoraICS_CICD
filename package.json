{
  "name": "calculadora-ics-cicd",
  "version": "1.0.0",
  "description": "Calculadora de promedio para Ingeniería y Calidad de Software",
  "private": true,
  "scripts": {
    "start": "node src/server.js",
    "test": "jest",
    "lint": "eslint .",
    "docker:build": "docker build -t calculadora-ics .",
    "build:local": "npm ci && npm run lint && npm test && npm run docker:build"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "eslint": "^8.57.0",
    "jest": "^29.0.0"
  },
  "jest": {
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "transform": {}
  }
}